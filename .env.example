# Agent Audit Trail - Environment Configuration

# ===== Agent Settings =====
AGENT_ID=my-ai-agent
AGENT_VERSION=1.0.0

# ===== Storage Configuration =====
STORAGE_PATH=./audit-data
STORAGE_TYPE=json

# Storage Types:
# - json: File-based JSON storage (default)
# - sqlite: SQLite database (coming soon)
# - postgres: PostgreSQL database (coming soon)

# ===== Features =====
AUTO_VERIFY=true
ENABLE_SIGNATURES=false
ENABLE_COMPRESSION=false

# AUTO_VERIFY: Automatically verify chain integrity after each write
# ENABLE_SIGNATURES: Add digital signatures to entries (coming soon)
# ENABLE_COMPRESSION: Compress stored data (coming soon)

# ===== Advanced Options =====
LOG_LEVEL=info
MAX_ENTRIES_PER_FILE=10000

# LOG_LEVEL: debug, info, warn, error
# MAX_ENTRIES_PER_FILE: Maximum entries before creating new file (for file-based storage)
