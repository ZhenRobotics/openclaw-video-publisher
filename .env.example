# OpenClaw Video Publisher - 环境变量配置

# ===== 默认设置 =====
DEFAULT_PLATFORMS=douyin,kuaishou,weixin,bilibili
AUTO_RETRY=true
MAX_RETRY=3
RETRY_DELAY=5
LOG_LEVEL=info
PUBLISH_HISTORY_PATH=./data/publish-history.json

# ===== 抖音开放平台 =====
DOUYIN_CLIENT_KEY=your-client-key
DOUYIN_CLIENT_SECRET=your-client-secret
DOUYIN_ACCESS_TOKEN=your-access-token

# ===== 快手开放平台 =====
KUAISHOU_APP_ID=your-app-id
KUAISHOU_APP_SECRET=your-app-secret
KUAISHOU_ACCESS_TOKEN=your-access-token

# ===== 微信视频号 =====
WEIXIN_CORP_ID=your-corp-id
WEIXIN_CORP_SECRET=your-corp-secret

# ===== 哔哩哔哩 =====
BILIBILI_ACCESS_KEY=your-access-key
BILIBILI_SECRET_KEY=your-secret-key
BILIBILI_SESSION_ID=your-session-id

# ===== YouTube =====
YOUTUBE_API_KEY=your-api-key
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# ===== TikTok =====
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_ACCESS_TOKEN=your-access-token
